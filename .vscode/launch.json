{
    "configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Run-client",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/node/run-client.mjs",
			"args": ["--max-old-space-size=16384", "-cp", "27259"],
			"runtimeArgs": ["--inspect"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Run-client-with-board-service",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/node/run-client.mjs",
			"args": ["--max-old-space-size=16384", "-cp", "27259", "--board-service"],
			"runtimeArgs": ["--inspect"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Run-public-with-board-service",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/node/run-public.mjs",
			"args": ["--max-old-space-size=16384", "-cp", "27259", "--board-service"],
			"runtimeArgs": ["--inspect"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Simul-Network",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/simulations/simul-network.js",
			"args": ["--max-old-space-size=16384", "--local", "-bootstraps", "1", "-clients", "2", "-stakers", "1", "-spammers", "1", "-nor", "2000", "-nos", "200"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Board-Service-standalone",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/node/board-service.mjs",
			"args": ["--start"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Run 2 Nodes",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/simulations-single-thread/run_2_nodes.js"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Worst TXs Validations",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/simulations-single-thread/test-worst-txs-validations.js",
			"args": ["--max-old-space-size=16384"],
			"runtimeArgs": ["--inspect"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Staking",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/simulations-single-thread/test-staking.js",
			"args": ["--max-old-space-size=16384"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Sync",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/simulations-single-thread/test_sync.js"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Storage",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/unit-tests/test-storage.js"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Build Extension",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/build/extension/build.js"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Build Desktop",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/build/desktop/build.js"
		}
    ]
}