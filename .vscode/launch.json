{
    "configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Run-client",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/node/run-client.mjs",
			"args": ["-cp", "27259"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Board Service",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/board-service.mjs",
			"args": ["--start"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Build Extension",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/build/extension/build.js"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Build Desktop",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/build/desktop/build.js"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Run 2 Nodes",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/run_2_nodes.js",
			"args": ["--max-old-space-size=16384"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Worst TXs Validations",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/test-worst-txs-validations.js",
			"args": ["--max-old-space-size=16384"],
			"runtimeArgs": ["--inspect"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Staking",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/test-staking.js",
			"args": ["--max-old-space-size=16384"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Solving",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/test-solving.js",
			"args": ["--max-old-space-size=16384"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Sync",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/tests/test_sync.js",
			"args": ["--max-old-space-size=16384"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Test: Storage",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/storage/storage.mjs",
			"args": ["--max-old-space-size=16384"]
		}
    ]
}